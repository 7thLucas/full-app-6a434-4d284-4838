# ──────────────────────────────────────────────────────
# @qb/authentication — environment variables
# Copy these into the project root .env file
# ──────────────────────────────────────────────────────

# JWT — secret must be at least 32 characters long
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# App base URL — used in password reset email links
APP_URL=http://localhost:3000

# Admin seed — creates an admin user on first startup if none exists
# Set SEED_ADMIN_ENABLE=false to disable
SEED_ADMIN_ENABLE=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
